# --- config-service ---
PORT=3000

# Consul (used by GET /config/publish and yarn publish:consul)
CONSUL_HTTP_ADDR=http://localhost:8500
CONSUL_HTTP_TOKEN=
GIT_COMMIT=local-demo
PUBLISH_DRY_RUN=false

# GitHub (used by POST /admin/assets/create-pr)
# Token needs `repo` scope on the target repository.
GITHUB_TOKEN=ghp_xxx_replace_me
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=demo-config-platform
GITHUB_BASE_BRANCH=staging
